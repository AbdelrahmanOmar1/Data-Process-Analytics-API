generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/* ================== ITEM MASTER ================== */
model Item {
  id        Int      @id @default(autoincrement())
  itemCode  String   @unique
  itemName  String?

  sales     Sale[]
  purchases Purchase[]
}

/* ================== SALES ================== */
model Sale {
  id        Int    @id @default(autoincrement())
  itemCode  String
  qty       Float
  value     Float

  item      Item?  @relation(fields: [itemCode], references: [itemCode])
}

/* ================== PURCHASES ================== */
model Purchase {
  id        Int    @id @default(autoincrement())
  itemCode  String
  qty       Float
  value     Float

  item      Item?  @relation(fields: [itemCode], references: [itemCode])
}